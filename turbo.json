{
	"$schema": "https://turbo.build/schema.json",
	"globalPassThroughEnv": ["DATABASE_URL"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".output/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"test:e2e": {
			"dependsOn": ["build"]
		},
		"lint": {},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"db:generate": {
			"cache": false
		},
		"db:push": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:migrate:deploy": {
			"cache": false
		}
	}
}
