DATABASE_URL="postgresql://nwords:nwords@localhost:5432/nwords"
# Optional: pg pool size for Prisma adapter (default 20). Raise if many concurrent txs (ingest + API).
DATABASE_POOL_MAX="20"
# Optional: Prisma interactive transaction wait/execution limits in ms (defaults 20000 / 120000).
PRISMA_TX_MAX_WAIT_MS="20000"
PRISMA_TX_TIMEOUT_MS="120000"
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
# Use http://localhost:3000 for normal dev. For Google OAuth locally, run `pnpm tunnel`, copy the https URL here, restart `pnpm dev`, and add the same URL + /api/auth/callback/google in Google Cloud Console.
BETTER_AUTH_URL="http://localhost:3000"
# Google OAuth (https://console.cloud.google.com/apis/credentials) — redirect must be exactly {BETTER_AUTH_URL}/api/auth/callback/google (localhost and/or your ngrok URL).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# "true" shows "Continue with Google" when GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are set.
GOOGLE_AUTH_ENABLED=false
# ngrok (https://dashboard.ngrok.com/get-started/your-authtoken) — used by `pnpm tunnel` only.
NGROK_AUTHTOKEN=""
# Optional (paid ngrok only): reserved domain so BETTER_AUTH_URL stays stable. Free tier: leave unset — you get a random *.ngrok-free.app URL like the `ngrok http 3000` CLI.
# NGROK_DOMAIN=""
# NGROK_LOCAL_PORT=3000
# Optional: password for the seeded admin (default in seed is dev-only; set for real deployments)
SEED_ADMIN_PASSWORD=""
POSTHOG_KEY=""
OPENAI_API_KEY=""
# Ingestion: pg-boss uses DATABASE_URL. If "true" on apps/api, no Kaikki/Tatoeba workers run — jobs stay PENDING with no output (OK for tests / API-only processes).
DISABLE_INGEST_WORKERS=false
# For `turbo dev`, you may set DISABLE_INGEST_WORKERS=true on the **web** app only so the web dev server does not register workers; apps/api must have it false so one Node process consumes queues.
# Mark IngestionJob rows stuck in RUNNING longer than this (minutes) as FAILED. Set 0 to disable sweeps entirely.
STALE_INGESTION_JOB_MINUTES=120
# How often to repeat that sweep when ingest workers are enabled (ms). Set 0 for startup-only sweep (once per worker process).
STALE_INGESTION_SWEEP_INTERVAL_MS=600000
# If Kaikki HEAD probes fail (some proxies), force the single monolith JSONL instead of four per-POS files.
KAIKKI_FORCE_MONOLITH=false
# Optional: raises GitHub API rate limits when resolving hermitdave/FrequencyWords list URLs (public repo works without it).
GITHUB_TOKEN=""
AWS_REGION="us-east-1"
S3_BUCKET=""
CLOUDFRONT_DOMAIN=""
