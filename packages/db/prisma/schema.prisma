generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth Models ─────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  /// Better Auth anonymous plugin — guest learner before linking email/OAuth.
  isAnonymous   Boolean  @default(false)
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  nativeLanguageId String?   @db.Uuid
  targetLanguageId String?   @db.Uuid
  nativeLanguage   Language? @relation("NativeLanguage", fields: [nativeLanguageId], references: [id])
  targetLanguage   Language? @relation("TargetLanguage", fields: [targetLanguageId], references: [id])

  sessions      Session[]
  accounts      Account[]
  verifications Verification[]
  wordKnowledge    UserWordKnowledge[]
  languageProfiles UserLanguageProfile[]
  scoreHistory     ScoreHistory[]
  testSessions     TestSession[]
  clozeIssueReports ClozeIssueReport[]

  @@map("user")
}

enum Role {
  USER
  ADMIN
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification")
}

// ─── Language ───────────────────────────────────────────

model Language {
  id                   String   @id @default(uuid()) @db.Uuid
  code                 String   @unique
  code3                String?
  name                 String
  /// Slug for kaikki.org URLs (e.g. "Finnish"). Defaults to `name` when starting ingestion.
  kaikkiDictionaryName String?
  enabled              Boolean  @default(false)
  createdAt            DateTime @default(now())

  words          Word[]
  wordForms      WordForm[]
  sentences      Sentence[]      @relation("SentenceLanguage")
  nativeSpeakers User[]          @relation("NativeLanguage")
  targetLearners User[]          @relation("TargetLanguage")
  frequencyLists FrequencyList[]
  userProfiles   UserLanguageProfile[]
  guestSessionsNative TestSession[] @relation("GuestTestNativeLanguage")
  guestSessionsTarget TestSession[] @relation("GuestTestTargetLanguage")
  clozeReportsAsNative ClozeIssueReport[] @relation("ClozeReportNative")
  clozeReportsAsTarget ClozeIssueReport[] @relation("ClozeReportTarget")
  posMismatchMessages    PosMismatchMessage[]
  fixedExpressionRules   FixedExpressionRule[]
  wordSynonymPairs       WordSynonymPair[]

  @@map("language")
}

// ─── Words ──────────────────────────────────────────────

model Word {
  id              String       @id @default(uuid()) @db.Uuid
  languageId      String       @db.Uuid
  language        Language     @relation(fields: [languageId], references: [id])
  lemma           String
  pos             PartOfSpeech
  alternatePos    PartOfSpeech[] @default([])
  rank            Int
  definitions     Json
  isOffensive     Boolean      @default(false)
  /// Excluded from frequency rank, cloze tests, and vocab graph (abbreviations / initialisms).
  isAbbreviation  Boolean      @default(false)
  /// Whether this word is presented in vocabulary tests. False for function-word POS types.
  isTestable      Boolean      @default(true)
  cefrLevel       CefrLevel?
  /// Admin-set offset added to `rank` when computing `effectiveRank`. Default 0 = no shift.
  positionAdjust  Int          @default(0)
  /// Materialised rank used for all ordering: `rank + positionAdjust`. Recomputed on frequency import and admin adjust.
  effectiveRank   Int          @default(0)
  /// Curated sentence UUIDs suitable for vocabulary tests (ranked by quality).
  testSentenceIds String[]     @default([])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  sentenceWords SentenceWord[]
  userKnowledge UserWordKnowledge[]
  forms         WordForm[]
  clozeIssueReports ClozeIssueReport[]
  synonymPairsAsLow  WordSynonymPair[] @relation("SynonymWordLow")
  synonymPairsAsHigh WordSynonymPair[] @relation("SynonymWordHigh")

  @@unique([languageId, lemma, pos])
  @@index([languageId, rank])
  @@index([languageId, effectiveRank])
  @@index([languageId, cefrLevel])
  @@map("word")
}

// ─── Word Forms (inflections / conjugations) ────────────


model WordForm {
  id         String   @id @default(uuid()) @db.Uuid
  languageId String   @db.Uuid
  form       String
  wordId     String   @db.Uuid
  tags       Json     @default("[]")

  language   Language @relation(fields: [languageId], references: [id])
  word       Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([languageId, form, wordId])
  @@index([languageId, form])
  @@index([wordId])
  @@map("word_form")
}

/// Admin-curated same-language word pairs for cloze synonym feedback (bidirectional).
enum SynonymQuality {
  GOOD
  BAD
}

model WordSynonymPair {
  id         String         @id @default(uuid()) @db.Uuid
  languageId String         @db.Uuid
  language   Language       @relation(fields: [languageId], references: [id], onDelete: Restrict)
  /// Always `min(wordA.id, wordB.id)` — enforced when writing.
  wordIdLow  String         @db.Uuid
  /// Always `max(wordA.id, wordB.id)`.
  wordIdHigh String         @db.Uuid
  wordLow    Word           @relation("SynonymWordLow", fields: [wordIdLow], references: [id], onDelete: Cascade)
  wordHigh   Word           @relation("SynonymWordHigh", fields: [wordIdHigh], references: [id], onDelete: Cascade)
  quality    SynonymQuality
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([languageId, wordIdLow, wordIdHigh])
  @@index([languageId, wordIdLow])
  @@index([languageId, wordIdHigh])
  @@map("word_synonym_pair")
}

enum PartOfSpeech {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PRONOUN
  DETERMINER
  PREPOSITION
  CONJUNCTION
  PARTICLE
  INTERJECTION
  NUMERAL
  PROPER_NOUN
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

// ─── Frequency Lists ────────────────────────────────────

model FrequencyList {
  id         String   @id @default(uuid()) @db.Uuid
  languageId String   @db.Uuid
  language   Language @relation(fields: [languageId], references: [id])
  source     String
  version    String?
  importedAt DateTime @default(now())

  @@unique([languageId, source])
  @@map("frequency_list")
}

// ─── Sentences ──────────────────────────────────────────

model Sentence {
  id         String   @id @default(uuid()) @db.Uuid
  tatoebaId  Int?     @unique
  languageId String   @db.Uuid
  language   Language @relation("SentenceLanguage", fields: [languageId], references: [id])
  text       String
  hasAudio   Boolean  @default(false)
  audioS3Key String?
  /// Heuristic 0–1 quality for use in translation / cloze tests.
  testQualityScore Float?
  isTestCandidate  Boolean  @default(false)
  /// Flagged by admin via cloze issue report — excluded from cloze tests at runtime.
  markedForRemoval Boolean  @default(false)
  createdAt  DateTime @default(now())

  translations  SentenceTranslation[] @relation("OriginalSentence")
  translatedBy  SentenceTranslation[] @relation("TranslatedSentence")
  sentenceWords SentenceWord[]

  @@index([languageId])
  /// Speeds up Tatoeba linking: rows needing first-pass link (`testQualityScore` null) per language.
  @@index([languageId, testQualityScore])
  @@map("sentence")
}

model SentenceTranslation {
  id                   String   @id @default(uuid()) @db.Uuid
  originalSentenceId   String   @db.Uuid
  translatedSentenceId String   @db.Uuid
  originalSentence     Sentence @relation("OriginalSentence", fields: [originalSentenceId], references: [id])
  translatedSentence   Sentence @relation("TranslatedSentence", fields: [translatedSentenceId], references: [id])

  @@unique([originalSentenceId, translatedSentenceId])
  @@map("sentence_translation")
}

model SentenceWord {
  id         String   @id @default(uuid()) @db.Uuid
  sentenceId String   @db.Uuid
  wordId     String   @db.Uuid
  sentence   Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  word       Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  position   Int

  @@unique([sentenceId, wordId])
  @@index([wordId])
  @@map("sentence_word")
}

// ─── User Language Profile ──────────────────────────────

model UserLanguageProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  languageId  String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language    Language @relation(fields: [languageId], references: [id])
  assumedRank Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, languageId])
  @@map("user_language_profile")
}

// ─── User Word Knowledge ────────────────────────────────

model UserWordKnowledge {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  wordId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word         Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)
  confidence   Float     @default(0.5)
  timesTested  Int       @default(0)
  timesCorrect Int       @default(0)
  lastTestedAt DateTime?
  lastCorrect  Boolean   @default(false)
  streak       Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, wordId])
  @@index([userId, confidence])
  @@map("user_word_knowledge")
}

// ─── Scores ─────────────────────────────────────────────

model ScoreHistory {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  actualScore Int
  targetScore Int
  cefrLevel   CefrLevel?
  recordedAt  DateTime   @default(now())

  @@index([userId, recordedAt])
  @@map("score_history")
}

// ─── Test Sessions ──────────────────────────────────────

model TestSession {
  id                String     @id @default(uuid()) @db.Uuid
  userId            String?    @db.Uuid
  user              User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// For guest (logged-out) sessions only — paired with `targetLanguageId`.
  nativeLanguageId  String?    @db.Uuid
  nativeLanguage    Language?  @relation("GuestTestNativeLanguage", fields: [nativeLanguageId], references: [id])
  targetLanguageId  String?    @db.Uuid
  targetLanguage    Language?  @relation("GuestTestTargetLanguage", fields: [targetLanguageId], references: [id])
  mode              TestMode
  vocabMode         VocabMode  @default(BUILD)
  startedAt         DateTime   @default(now())
  endedAt           DateTime?
  wordsTestedCount  Int        @default(0)
  wordsCorrectCount Int        @default(0)
  /// NEWWORDS: ordered queue of lemmas for this session. (Optional PATCH on BUILD for legacy tooling.)
  columnFocusWordIds Json?

  answers TestAnswer[]

  @@index([userId, startedAt])
  @@map("test_session")
}

enum TestMode {
  MULTIPLE_CHOICE
  TRANSLATION
  VOICE
  MIXED
}

enum VocabMode {
  ASSESSMENT
  BUILD
  FRUSTRATION
  NEWWORDS
}

model TestAnswer {
  id            String      @id @default(uuid()) @db.Uuid
  testSessionId String      @db.Uuid
  testSession   TestSession @relation(fields: [testSessionId], references: [id], onDelete: Cascade)
  wordId        String      @db.Uuid
  sentenceId    String?     @db.Uuid
  answerType    AnswerType
  userAnswer    String?
  correct       Boolean
  wasTypo       Boolean     @default(false)
  timeTakenMs   Int?
  answeredAt    DateTime    @default(now())

  @@index([testSessionId])
  @@map("test_answer")
}

enum AnswerType {
  MULTIPLE_CHOICE
  TRANSLATION_TYPED
  VOICE_TRANSCRIPTION
}

/// User-reported bad cloze items (training / debugging).
enum ClozeIssueStatus {
  PENDING
  REMOVE_CANDIDATE
  SENTENCE_REMOVED
  CLUE_CORRECTED
  DISMISSED
  /// Reporter's guess registered as an acceptable synonym for the target word.
  GOOD_SYNONYM
  /// Reporter's guess registered as a non-synonym (explicit mismatch) for the target word.
  BAD_SYNONYM
  /// Target lemma marked non-testable (`Word.isTestable` false); excluded from cloze / heatmap pools.
  EXCLUDED_FROM_TESTS
}

model ClozeIssueReport {
  id               String           @id @default(uuid()) @db.Uuid
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  reporterUserId   String?          @db.Uuid
  reporter         User?            @relation(fields: [reporterUserId], references: [id], onDelete: SetNull)
  nativeLanguageId String           @db.Uuid
  nativeLanguage   Language         @relation("ClozeReportNative", fields: [nativeLanguageId], references: [id])
  targetLanguageId String           @db.Uuid
  targetLanguage   Language         @relation("ClozeReportTarget", fields: [targetLanguageId], references: [id])
  wordId           String           @db.Uuid
  word             Word             @relation(fields: [wordId], references: [id])
  targetSentenceId String?          @db.Uuid
  hintSentenceId   String?          @db.Uuid
  targetSentenceText String         @db.Text
  promptText       String           @db.Text
  hintText         String           @db.Text
  hintSource       String
  inlineHint       String?          @db.Text
  /// What the user typed when they reported (if any).
  userGuess        String?          @db.Text
  wordLemma        String
  status           ClozeIssueStatus @default(PENDING)
  adminCorrectClue String?          @db.Text
  adminNote        String?          @db.Text

  @@index([targetLanguageId, status])
  @@index([createdAt])
  @@map("cloze_issue_report")
}

// ─── Ingestion Jobs ─────────────────────────────────────

model IngestionJob {
  id             String          @id @default(uuid()) @db.Uuid
  type           IngestionType
  languageId     String          @db.Uuid
  status         IngestionStatus @default(PENDING)
  totalItems     Int             @default(0)
  processedItems Int             @default(0)
  errorCount     Int             @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  metadata       Json?

  @@index([status])
  @@map("ingestion_job")
}

enum IngestionType {
  KAIKKI_WORDS
  FREQUENCY_LIST
  TATOEBA_SENTENCES
  WORD_FORMS
  AUDIO_FILES
  FIXED_EXPRESSIONS
}

enum IngestionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ─── Fixed Expression Rules ───────────────────────────

model FixedExpressionRule {
  id         String   @id @default(uuid()) @db.Uuid
  languageId String   @db.Uuid
  language   Language @relation(fields: [languageId], references: [id])
  /// Word that must appear in the cloze sentence for this rule to fire.
  trigger    String
  /// The correct particle/preposition the exercise expects.
  required   String
  /// Common wrong guesses this rule can explain.
  invalid    String[]
  /// The full fixed expression (e.g. "tycka om").
  expression String
  /// English meaning of the expression (e.g. "to like").
  meaning    String

  @@unique([languageId, trigger, required])
  @@index([languageId])
  @@map("fixed_expression_rule")
}

// ─── POS Mismatch Messages ─────────────────────────────

model PosMismatchMessage {
  id         String       @id @default(uuid()) @db.Uuid
  languageId String       @db.Uuid
  language   Language     @relation(fields: [languageId], references: [id])
  guessPos   PartOfSpeech
  targetPos  PartOfSpeech
  message    String

  @@unique([languageId, guessPos, targetPos])
  @@map("pos_mismatch_message")
}

// ─── Deploy / site configuration (singleton row) ───────

model AppSettings {
  id        String   @id
  showHints Boolean  @default(false)
  aiProvider String?  @map("ai_provider")
  aiModel    String?  @map("ai_model")
  aiApiKey   String?  @map("ai_api_key")
  /// Build-mode tuning (merged with code defaults). See `VocabBuildSettings` in @nwords/shared.
  vocabBuildSettings Json? @map("vocab_build_settings")
  /// Global heatmap color palette (VocabGraphColors). Null = code defaults apply.
  vocabGraphColors Json? @map("vocab_graph_colors")
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
